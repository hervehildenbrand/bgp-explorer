# BGP Explorer Environment Configuration

# ============================================
# AI Backend (required)
# ============================================

# Anthropic Claude API key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Data Sources (all optional)
# ============================================

# bgp-radar for real-time anomaly detection
# Install: go install github.com/hervehildenbrand/bgp-radar/cmd/bgp-radar@latest
# BGP_RADAR_PATH=/path/to/bgp-radar

# MANRS Observatory API key (optional, for official conformance data)
# Register free at https://manrs.org/resources/api/
# IMPORTANT: If using Claude Desktop MCP, also add this key to
# ~/Library/Application Support/Claude/claude_desktop_config.json
# in the bgp-explorer env block (MCP process does NOT read .env)
# MANRS_API_KEY=your_manrs_api_key_here

# ============================================
# Data Sources Enabled by Default
# ============================================
# - RIPE Stat API (no config needed)
# - Globalping API (no config needed)
# - BGPStream (requires: brew install bgpstream && uv sync --extra bgpstream)
